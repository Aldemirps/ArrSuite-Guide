# Ignore everything by default
*

# But include our documentation files
!.gitignore
!README.md
!ARR_STACK_SETUP.md
!ARCHITECTURE.md
!ct-add-storage.sh
!nfs-setup.sh
!vpn-setup.sh
!VPN_SPLIT_TUNNEL_SETUP.md
!VPN_GETTING_STARTED.md
!surfshark-template.conf
!example-configs/
!example-configs/**
!LICENSE

# Ignore system files
.bash_history
.bashrc
.profile
.cache/
.dotnet/
.forward
.install-*.log
.local/
.rnd
.ssh/
.vscode-server/
.wget-hsts

# Ignore project planning files
PLAN.md
immich-upload-guide.md

# Ignore sensitive VPN configs (contain private keys!)
*.conf
ae-dub.conf
wg*.conf

# But allow the template (no sensitive data)
!surfshark-template.conf
